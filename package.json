{
  "name": "rrb",
  "private": true,
  "version": "1.0.1",
  "scripts": {
    "dev:web": "bun --cwd apps/web run dev",
    "build:web": "bun --cwd apps/web run build",
    "start:web": "bun --cwd apps/web run start",
    "lint:web": "bun --cwd apps/web run lint",
    "dev:mobile": "bun --cwd apps/mobile run start",
    "start:mobile": "bun --cwd apps/mobile run start",
    "android:mobile": "bun --cwd apps/mobile run android",
    "ios:mobile": "bun --cwd apps/mobile run ios",
    "web:mobile": "bun --cwd apps/mobile run web",
    "lint:mobile": "bun --cwd apps/mobile run lint",
    "lint": "bun run lint:web && bun run lint:mobile"
  },
  "workspaces": [
    "apps/*"
  ]
}
